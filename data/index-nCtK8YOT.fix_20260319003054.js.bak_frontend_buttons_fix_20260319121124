;(()=>{try{
const __scormNormalize=t=>(t||"").replace(/\s+/g," ").trim();

function __scormRemoveImprovementBlocks(){
  const all=[...document.querySelectorAll("div,section,article,aside,form,li")];

  const candidates=all.filter(el=>{
    const text=__scormNormalize(el.textContent);
    if(!text) return false;
    const hasTitle=text.includes("Хотите улучшить результат?");
    const hasRetry=text.includes("Пройти еще раз");
    const hasNext=text.includes("Дальше");
    return hasTitle&&(hasRetry||hasNext);
  });

  if(!candidates.length) return;

  const minimal=candidates.filter(el=>!candidates.some(other=>other!==el&&el.contains(other)));

  for(const el of minimal){
    if(!el.isConnected) continue;
    el.style.setProperty("display","none","important");
    el.setAttribute("data-scorm-hidden-improvement","1");
  }
}

function __scormBootHideImprovementBlocks(){
  __scormRemoveImprovementBlocks();

  const observer=new MutationObserver(()=>{
    __scormRemoveImprovementBlocks();
  });

  observer.observe(document.documentElement||document.body,{
    childList:true,
    subtree:true
  });

  window.addEventListener("load",__scormRemoveImprovementBlocks,{once:false});
  document.addEventListener("readystatechange",__scormRemoveImprovementBlocks);
}

if(document.readyState==="loading"){
  document.addEventListener("DOMContentLoaded",__scormBootHideImprovementBlocks,{once:true});
}else{
  __scormBootHideImprovementBlocks();
}
}catch(e){console && console.warn && console.warn("scorm improvement block hide failed",e)}})();

